{
  "manifest_version": 2,
  "name": "LinkedIn Ad Blocker",
  "version": "1.0",
  "description": "Blocks LinkedIn promoted posts.",
  "permissions": [
    "tabs",
    "webNavigation",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
